AwAgCdASoQAA0ABUB8JbACxJUAB5vpX0FsAAD+xcWH3wpF0jhDcxUNJ1+foswttR5dRvY4/fm0D+vXVAIlPUDj+6uSv4qwF+gwJbeELf8NFz1WaR+wpkXEnsWBkao2y4j7pgjeuAA="},"visualSmall":{"id":17543076,"alt":"","name":"","focus":"","title":"","source":"","filename":"https://a.storyblok.com/f/191576/1176x448/a22b6c1340/source_nick_hawkins.webp","copyright":"","fieldtype":"asset","meta_data":{},"is_external_url":false,"blurDataURL":"data:image/webp;base64,UklGRkwAAABXRUJQVlA4IEAAAADQAQCdASoQAAYABUB8JaAAAtsMXyFCsAD+muuL8Q6/mqwQjGYXykzysvSfuT5ChySNmTZhXkipL4V+gRX4XvAA"},"authorJobTitle":"Founder, The 1994 Candle Co.","cssBackgroundColor":"#FFEEE5"}],"title":[{"_uid":"5c45741d-2a8a-4ea3-a066-ee0d972260d6","title":"Photoroom is loved by companies of all sizes","variant":"","overline":"Customer stories","subtitle":"See real stories from businesses like yours.","component":"SectionTitle"}],"component":"CustomerStoriesBlock"},{"_uid":"2bea325b-523f-40f9-9da5-63368d03a0ae","items":[{"_uid":"0dcb1110-084b-4263-9695-a17b5483e58b","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Photoroom’s AI Backgrounds use advanced object recognition and generative AI to analyze your image, detect the subject, and create realistic, on-brand scenes around it. This results in natural-looking compositions that make your product stand out without any manual editing.","type":"text","marks":[{"type":"textStyle","attrs":{"color":"#000000"}}]}]}]},"question":"How does an AI background generator create realistic scenes for photos?","component":"FaqItem"},{"_uid":"d31ea4e3-d64b-4820-88a2-fc81f4dbb14c","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"With Photoroom, you can generate fully custom backgrounds using ","type":"text","marks":[{"type":"textStyle","attrs":{"color":"#000000"}}]},{"text":"text prompts","type":"text","marks":[{"type":"link","attrs":{"href":"/blog/image-prompting","uuid":"5562d232-a77b-4bb7-a064-95223f60f4d6",